<model>
    <mount>//OPNsense/Vpnlink</mount>
    <version>3.0.0</version>
    <description>VPN Traffic Orchestrator</description>

    <items>
        <general>
            <enabled type="BooleanField">
                <default>0</default>
                <Required>Y</Required>
            </enabled>
        </general>

        <!-- Each link: WG source → LAN to mirror -->
        <links>
            <link type="ArrayField">
                <enabled type="BooleanField">
                    <default>1</default>
                    <Required>Y</Required>
                </enabled>

                <name type="TextField">
                    <Required>Y</Required>
                    <Mask>/^[a-zA-Z0-9_ \-]{1,64}$/</Mask>
                    <ValidationMessage>Name for this link</ValidationMessage>
                </name>

                <source type="TextField">
                    <Required>Y</Required>
                    <Mask>/^(any|[0-9\.\/, ]+)$/</Mask>
                    <ValidationMessage>WireGuard source(s): "any", or comma-separated IPs/subnets</ValidationMessage>
                </source>

                <lanInterface type="TextField">
                    <Required>Y</Required>
                    <Mask>/^[a-zA-Z0-9_]{1,32}$/</Mask>
                    <ValidationMessage>LAN interface to mirror (e.g. opt1)</ValidationMessage>
                </lanInterface>

                <cloneRules type="BooleanField">
                    <default>1</default>
                    <Required>Y</Required>
                </cloneRules>

                <autoNat type="BooleanField">
                    <default>1</default>
                    <Required>Y</Required>
                </autoNat>

                <dnsSync type="BooleanField">
                    <default>1</default>
                    <Required>Y</Required>
                </dnsSync>
            </link>
        </links>
    </items>
</model>
