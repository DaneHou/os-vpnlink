<model>
    <mount>//OPNsense/Vpnlink</mount>
    <version>3.0.0</version>
    <description>VPN Traffic Orchestrator</description>

    <items>
        <general>
            <enabled type="BooleanField">
                <default>0</default>
                <Required>Y</Required>
            </enabled>
        </general>

        <!-- Each link: WG source → LAN to mirror -->
        <links>
            <link type="ArrayField">
                <enabled type="BooleanField">
                    <default>1</default>
                    <Required>Y</Required>
                </enabled>

                <name type="TextField">
                    <Required>Y</Required>
                    <Mask>/^[a-zA-Z0-9_ \-]{1,64}$/</Mask>
                    <ValidationMessage>Name for this link</ValidationMessage>
                </name>

                <source type="TextField">
                    <Required>Y</Required>
                    <Mask>/^(any|([0-9]{1,3}\.){3}[0-9]{1,3}(\/[0-9]{1,2})?)$/</Mask>
                    <ValidationMessage>WireGuard source: "any", IP (10.10.0.2), or subnet (10.10.0.0/24)</ValidationMessage>
                </source>

                <lanInterface type="TextField">
                    <Required>Y</Required>
                    <Mask>/^[a-zA-Z0-9_]{1,32}$/</Mask>
                    <ValidationMessage>LAN interface to mirror (e.g. opt1)</ValidationMessage>
                </lanInterface>
            </link>
        </links>
    </items>
</model>
