<model>
    <mount>//OPNsense/Vpnlink</mount>
    <version>2.0.0</version>
    <description>VPN Traffic Orchestrator</description>

    <items>
        <general>
            <enabled type="BooleanField">
                <default>0</default>
                <Required>Y</Required>
            </enabled>

            <lanInterface type="TextField">
                <Required>N</Required>
                <Mask>/^[a-zA-Z0-9_]{0,32}$/</Mask>
                <ValidationMessage>Interface name (e.g. opt1, lan)</ValidationMessage>
            </lanInterface>
        </general>

        <!-- Advanced: per-device gateway steering -->
        <devicelinks>
            <devicelink type="ArrayField">
                <enabled type="BooleanField">
                    <default>1</default>
                    <Required>Y</Required>
                </enabled>
                <name type="TextField">
                    <Required>Y</Required>
                    <Mask>/^[a-zA-Z0-9_ \-]{1,64}$/</Mask>
                </name>
                <tunnelIp type="TextField">
                    <Required>Y</Required>
                    <Mask>/^([0-9]{1,3}\.){3}[0-9]{1,3}(\/[0-9]{1,2})?$/</Mask>
                </tunnelIp>
                <gateway type="TextField">
                    <Required>N</Required>
                    <Mask>/^[a-zA-Z0-9_\-]{0,64}$/</Mask>
                </gateway>
                <targetAlias type="TextField">
                    <Required>N</Required>
                    <Mask>/^[a-zA-Z0-9_]{0,31}$/</Mask>
                </targetAlias>
                <description type="TextField">
                    <Required>N</Required>
                    <Mask>/^.{0,128}$/</Mask>
                </description>
            </devicelink>
        </devicelinks>
    </items>
</model>
